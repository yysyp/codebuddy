{
    "comments": {
        "lineComment": "//",
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        {"open": "{", "close": "}"},
        {"open": "[", "close": "]"},
        {"open": "(", "close": ")"},
        {"open": "'", "close": "'", "notIn": ["string", "comment"]},
        {"open": "\"", "close": "\"", "notIn": ["string", "comment"]},
        {"open": "`", "close": "`", "notIn": ["string", "comment"]},
        {"open": "/**", "close": " */", "notIn": ["string"]}
    ],
    "surroundingPairs": [
        {"open": "{", "close": "}"},
        {"open": "[", "close": "]"},
        {"open": "(", "close": ")"},
        {"open": "'", "close": "'"},
        {"open": "\"", "close": "\""},
        {"open": "`", "close": "`"}
    ],
    "indentationRules": {
        "increaseIndentPattern": "^((?!\\/\\/).)*\\{$",
        "decreaseIndentPattern": "^\\}"
    },
    "folding": {
        "markers": {
            "start": "^\\s*\\/\\*\\s*Region",
            "end": "^\\s*\\/\\*\\s*End\\s*Region\\s*\\*\\/"
        }
    }
}
