        KieBase configuration for transaction rules.
        Defines a knowledge base that includes all rules from the rules package.
    -->
    <kbase name="transactionKbase" packages="com.example.flink.rules">
        <ksession name="transactionKsession" 
                  type="stateless"
                  default="true"/>
    </kbase>
    
</kmodule>
